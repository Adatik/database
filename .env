# Platform secrets
ADMIN_JWT_SECRET=your-admin-jwt-secret-change-me   # for platform users
PROJECT_JWT_SECRET=your-project-jwt-secret-change-me # for project users
POSTGRES_PASSWORD=your-db-password-here
ANON_KEY=your-anon-key-here
ADMIN_KEY=your-admin-key-here

# Platform sign-up control (set to "true" to allow anyone to register)
ALLOW_PUBLIC_SIGNUP=true

# When ALLOW_PUBLIC_SIGNUP=false, only this account can sign in
PLATFORM_ADMIN_EMAIL=admin@yourdomain.com
PLATFORM_ADMIN_PASSWORD=super-secure-password
